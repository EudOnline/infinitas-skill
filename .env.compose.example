# Set these to the numeric uid/gid of the host account that should own .deploy/*.
# On Linux, run: id -u && id -g
INFINITAS_IMAGE=ghcr.io/replace-with-owner/infinitas-skill:main
INFINITAS_UID=1000
INFINITAS_GID=1000
INFINITAS_PUBLISH_HOST=127.0.0.1
INFINITAS_PUBLISH_PORT=8000

INFINITAS_HOST_REPO_PATH=./.deploy/repo
INFINITAS_HOST_DATA_PATH=./.deploy/data
INFINITAS_HOST_ARTIFACT_PATH=./.deploy/artifacts
INFINITAS_HOST_BACKUP_PATH=./.deploy/backups
INFINITAS_HOST_HOME_PATH=./.deploy/home

INFINITAS_RUNTIME_HOME=/srv/infinitas/home
INFINITAS_BACKUP_OUTPUT_DIR=/srv/infinitas/backups

INFINITAS_SERVER_ENV=production
INFINITAS_SERVER_ALLOWED_HOSTS=["127.0.0.1","localhost"]
INFINITAS_SERVER_DATABASE_URL=sqlite:////srv/infinitas/data/server.db
INFINITAS_SERVER_SECRET_KEY=change-me
INFINITAS_SERVER_BOOTSTRAP_USERS=[{"username":"maintainer","display_name":"Maintainer","role":"maintainer","token":"replace-maintainer-token"},{"username":"contributor","display_name":"Contributor","role":"contributor","token":"replace-contributor-token"}]
INFINITAS_SERVER_REPO_PATH=/srv/infinitas/repo
INFINITAS_SERVER_ARTIFACT_PATH=/srv/infinitas/artifacts
INFINITAS_SERVER_REPO_LOCK_PATH=/srv/infinitas/data/repo.lock
INFINITAS_REGISTRY_READ_TOKENS=[]
INFINITAS_SERVER_MIRROR_REMOTE=
INFINITAS_SERVER_MIRROR_BRANCH=
INFINITAS_SERVER_GIT_BRANCH=main
INFINITAS_SERVER_GIT_ORIGIN_URL=
INFINITAS_SERVER_GIT_USER_NAME=Infinitas Hosted Registry
INFINITAS_SERVER_GIT_USER_EMAIL=hosted-registry@example.com
INFINITAS_SERVER_REPO_BOOTSTRAP_RESET=0

INFINITAS_WORKER_POLL_INTERVAL=5
INFINITAS_BACKUP_LABEL=nightly
INFINITAS_PRUNE_KEEP_LAST=7
INFINITAS_INSPECT_LIMIT=10
INFINITAS_INSPECT_MAX_QUEUED_JOBS=10
INFINITAS_INSPECT_MAX_RUNNING_JOBS=2
INFINITAS_INSPECT_MAX_FAILED_JOBS=0
INFINITAS_INSPECT_MAX_WARNING_JOBS=0
INFINITAS_INSPECT_ALERT_WEBHOOK_URL=
INFINITAS_INSPECT_ALERT_FALLBACK_FILE=/srv/infinitas/backups/latest-inspect-alert.json

{
  "$schema": "../schemas/registry-sources.schema.json",
  "default_registry": "self",
  "registries": [
    {
      "name": "self",
      "kind": "git",
      "url": "https://github.com/EudOnline/infinitas-skill.git",
      "local_path": ".",
      "branch": "main",
      "priority": 100,
      "enabled": true,
      "trust": "private",
      "allowed_hosts": [
        "github.com"
      ],
      "allowed_refs": [
        "refs/heads/main"
      ],
      "pin": {
        "mode": "branch",
        "value": "main"
      },
      "update_policy": {
        "mode": "local-only"
      },
      "notes": "Primary private registry for local development and promotion"
    }
  ]
}

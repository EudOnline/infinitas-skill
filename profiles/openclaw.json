{
  "schema_version": 1,
  "platform": "openclaw",
  "runtime": {
    "skill_dir_candidates": [
      "skills",
      ".agents/skills",
      "~/.agents/skills",
      "~/.openclaw/skills"
    ],
    "entrypoint": "SKILL.md",
    "workspace_state_dir": ".openclaw/state",
    "session_store": ".openclaw/sessions"
  },
  "capabilities": {
    "supports_subagents": true,
    "supports_commands": true,
    "supports_plugins": true,
    "supports_background_tasks": true,
    "supports_cron_jobs": true,
    "supports_public_publish": true
  },
  "constraints": {
    "text_only_public_bundle": false,
    "public_license": "MIT-0",
    "size_budget_mb": 50,
    "runtime_model": "openclaw-native"
  },
  "contract": {
    "sources": [
      "https://docs.openclaw.ai/tools/skills",
      "https://docs.openclaw.ai/tools/subagents",
      "https://docs.openclaw.ai/plugins/building-plugins",
      "https://docs.openclaw.ai/automation/tasks",
      "https://docs.openclaw.ai/automation/cron-jobs",
      "https://docs.openclaw.ai/clawhub",
      "https://docs.openclaw.ai/clawhub/publishing",
      "https://docs.openclaw.ai/clawhub/skill-format",
      "https://docs.openclaw.ai/clawhub/security",
      "https://docs.openclaw.ai/tools/creating-skills"
    ],
    "last_verified": "2026-07-21"
  }
}

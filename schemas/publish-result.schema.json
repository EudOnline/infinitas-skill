{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/infinitas-skill/publish-result.schema.json",
  "title": "publish-skill result",
  "type": "object",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ok",
        "skill",
        "qualified_name",
        "version",
        "status",
        "state",
        "manifest_path",
        "bundle_path",
        "attestation_path",
        "commands",
        "promotion_required",
        "next_step"
      ],
      "properties": {
        "ok": { "const": true },
        "skill": { "type": "string", "minLength": 1 },
        "qualified_name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "state": { "const": "planned" },
        "manifest_path": { "type": "string", "minLength": 1 },
        "bundle_path": { "type": "string", "minLength": 1 },
        "attestation_path": { "type": "string", "minLength": 1 },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "promotion_required": { "type": "boolean" },
        "next_step": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ok",
        "skill",
        "qualified_name",
        "version",
        "state",
        "manifest_path",
        "bundle_path",
        "bundle_sha256",
        "attestation_path",
        "next_step"
      ],
      "properties": {
        "ok": { "const": true },
        "skill": { "type": "string", "minLength": 1 },
        "qualified_name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "state": { "const": "published" },
        "manifest_path": { "type": "string", "minLength": 1 },
        "bundle_path": { "type": "string", "minLength": 1 },
        "bundle_sha256": { "type": "string", "minLength": 1 },
        "attestation_path": { "type": "string", "minLength": 1 },
        "published_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_step": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ok",
        "state",
        "failed_at_step",
        "error_code",
        "message",
        "suggested_action"
      ],
      "properties": {
        "ok": { "const": false },
        "state": { "const": "failed" },
        "failed_at_step": { "type": "string", "minLength": 1 },
        "error_code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "suggested_action": { "type": "string", "minLength": 1 },
        "skill": { "type": "string", "minLength": 1 },
        "qualified_name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    }
  ]
}

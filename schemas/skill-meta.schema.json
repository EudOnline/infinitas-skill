{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/infinitas-skill/skill-meta.schema.json",
  "title": "infinitas-skill _meta.json",
  "type": "object",
  "additionalProperties": true,
  "$defs": {
    "dependencyRef": {
      "type": "string",
      "pattern": "^(?:(?:[a-z0-9]+(?:-[a-z0-9]+)*)/)?[a-z0-9]+(?:-[a-z0-9]+)*(?:@\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9_.-]+)?)?$"
    },
    "dependencyConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^(?:(?:[a-z0-9]+(?:-[a-z0-9]+)*)/)?[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(\\*|[<>=~^0-9][0-9A-Za-z.+\\-<>=~^, ]*)$"
        },
        "registry": {
          "type": "string",
          "minLength": 1
        },
        "allow_incubating": {
          "type": "boolean"
        }
      }
    }
  },
  "required": [
    "name",
    "version",
    "status",
    "summary",
    "owner",
    "review_state",
    "risk_level",
    "distribution"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9_.-]+)?$"
    },
    "publisher": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "qualified_name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "incubating",
        "active",
        "archived"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "maintainers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agent_compatible": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "derived_from": {
      "type": [
        "string",
        "null"
      ]
    },
    "replaces": {
      "type": [
        "string",
        "null"
      ]
    },
    "visibility": {
      "type": "string"
    },
    "maturity": {
      "type": "string",
      "minLength": 1
    },
    "quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "use_when": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "avoid_when": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "runtime_assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_state": {
      "type": "string",
      "enum": [
        "draft",
        "under-review",
        "approved",
        "rejected"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "requires": {
      "type": "object",
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "properties": {
        "skill_md": {
          "type": "string"
        }
      }
    },
    "tests": {
      "type": "object",
      "properties": {
        "smoke": {
          "type": "string"
        }
      }
    },
    "distribution": {
      "type": "object",
      "required": [
        "installable",
        "channel"
      ],
      "properties": {
        "installable": {
          "type": "boolean"
        },
        "channel": {
          "type": "string"
        }
      }
    },
    "snapshot_of": {
      "type": "string"
    },
    "snapshot_created_at": {
      "type": "string"
    },
    "snapshot_label": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/dependencyRef"
          },
          {
            "$ref": "#/$defs/dependencyConstraint"
          }
        ]
      }
    },
    "conflicts_with": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/dependencyRef"
          },
          {
            "$ref": "#/$defs/dependencyConstraint"
          }
        ]
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinitas-skill.local/schemas/policy-pack-selection.schema.json",
  "title": "Policy Pack Selection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "active_packs"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string"
    },
    "compatibility_version": {
      "type": "string",
      "minLength": 1
    },
    "active_packs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    }
  }
}

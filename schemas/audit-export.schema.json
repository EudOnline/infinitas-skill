{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinitas-skill.local/schemas/audit-export.schema.json",
  "title": "Audit Export",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "counts",
    "releases"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "counts": {
      "type": "object",
      "required": [
        "releases"
      ],
      "properties": {
        "releases": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "releases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "qualified_name",
          "version",
          "provenance_path"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "qualified_name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "provenance_path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

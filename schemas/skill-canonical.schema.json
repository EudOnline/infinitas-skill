{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinitas-skill.local/schemas/skill-canonical.schema.json",
  "title": "infinitas-skill canonical skill source",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "summary",
    "description",
    "instructions_body",
    "tool_intents",
    "verification"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "instructions_body": {
      "type": "string",
      "minLength": 1
    },
    "tool_intents": {
      "type": "object",
      "required": ["required", "optional"],
      "properties": {
        "required": {
          "type": "array",
          "items": {"type": "string"}
        },
        "optional": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "degrades_to": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "distribution": {
      "type": "object",
      "properties": {
        "public_publish_allowed": {"type": "boolean"},
        "text_only_required": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "verification": {
      "type": "object",
      "properties": {
        "smoke_prompts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "required_platforms": {
          "type": "array",
          "items": {"type": "string"}
        },
        "required_runtimes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "openclaw_runtime": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openai.invalid/infinitas-skill/provenance.schema.json",
  "title": "infinitas-skill release attestation",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "kind",
    "generated_at",
    "skill",
    "git",
    "source_snapshot",
    "registry",
    "dependencies",
    "attestation"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "skill-release-attestation"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "skill": {
      "type": "object",
      "required": [
        "name",
        "version",
        "status",
        "path"
      ],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "status": {"type": ["string", "null"]},
        "path": {"type": "string", "minLength": 1},
        "derived_from": {"type": ["string", "null"]},
        "snapshot_of": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "git": {
      "type": "object",
      "required": [
        "commit",
        "expected_tag",
        "release_ref",
        "signed_tag_verified",
        "tag_signer"
      ],
      "properties": {
        "repo_url": {"type": ["string", "null"]},
        "branch": {"type": ["string", "null"]},
        "upstream": {"type": ["string", "null"]},
        "commit": {"type": "string", "minLength": 1},
        "head_commit": {"type": ["string", "null"]},
        "expected_tag": {"type": "string", "minLength": 1},
        "release_ref": {"type": "string", "minLength": 1},
        "remote": {"type": ["string", "null"]},
        "remote_tag_object": {"type": ["string", "null"]},
        "remote_tag_commit": {"type": ["string", "null"]},
        "signed_tag_verified": {"type": "boolean"},
        "tag_signer": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "source_snapshot": {
      "type": "object",
      "required": [
        "kind",
        "tag",
        "ref",
        "commit",
        "immutable",
        "pushed"
      ],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "tag": {"type": "string", "minLength": 1},
        "ref": {"type": "string", "minLength": 1},
        "commit": {"type": "string", "minLength": 1},
        "remote": {"type": ["string", "null"]},
        "upstream": {"type": ["string", "null"]},
        "immutable": {"type": "boolean"},
        "pushed": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "registry": {
      "type": "object",
      "required": [
        "default_registry",
        "registries_consulted",
        "resolved"
      ],
      "properties": {
        "default_registry": {"type": ["string", "null"]},
        "registries_consulted": {
          "type": "array",
          "items": {"type": "string"}
        },
        "resolved": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "registry_name": {"type": ["string", "null"]},
              "registry_kind": {"type": ["string", "null"]},
              "registry_url": {"type": ["string", "null"]},
              "registry_host": {"type": ["string", "null"]},
              "registry_priority": {"type": ["integer", "number"]},
              "registry_trust": {"type": ["string", "null"]},
              "registry_root": {"type": ["string", "null"]},
              "registry_pin_mode": {"type": ["string", "null"]},
              "registry_pin_value": {"type": ["string", "null"]},
              "registry_ref": {"type": ["string", "null"]},
              "registry_allowed_refs": {"type": "array", "items": {"type": "string"}},
              "registry_allowed_hosts": {"type": "array", "items": {"type": "string"}},
              "registry_update_mode": {"type": ["string", "null"]},
              "registry_commit": {"type": ["string", "null"]},
              "registry_tag": {"type": ["string", "null"]},
              "registry_branch": {"type": ["string", "null"]},
              "registry_origin_url": {"type": ["string", "null"]},
              "registry_origin_host": {"type": ["string", "null"]},
              "missing": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "dependencies": {
      "type": "object",
      "required": [
        "mode",
        "root",
        "steps",
        "registries_consulted"
      ],
      "properties": {
        "mode": {"type": ["string", "null"]},
        "root": {
          "type": "object",
          "properties": {
            "name": {"type": ["string", "null"]},
            "version": {"type": ["string", "null"]},
            "registry": {"type": ["string", "null"]},
            "stage": {"type": ["string", "null"]},
            "path": {"type": ["string", "null"]}
          },
          "additionalProperties": true
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "order": {"type": ["integer", "number"]},
              "name": {"type": ["string", "null"]},
              "version": {"type": ["string", "null"]},
              "registry": {"type": ["string", "null"]},
              "stage": {"type": ["string", "null"]},
              "path": {"type": ["string", "null"]},
              "relative_path": {"type": ["string", "null"]},
              "action": {"type": ["string", "null"]},
              "needs_apply": {"type": "boolean"},
              "requested_by": {"type": "array"},
              "depends_on": {"type": "array"},
              "conflicts_with": {"type": "array"},
              "root": {"type": "boolean"},
              "source_commit": {"type": ["string", "null"]},
              "source_ref": {"type": ["string", "null"]},
              "source_tag": {"type": ["string", "null"]}
            },
            "additionalProperties": true
          }
        },
        "registries_consulted": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "attestation": {
      "type": "object",
      "required": [
        "format",
        "namespace",
        "allowed_signers",
        "signature_file",
        "signature_ext",
        "signer_identity",
        "policy_mode",
        "require_verified_attestation_for_release_output",
        "require_verified_attestation_for_distribution"
      ],
      "properties": {
        "format": {"type": "string", "const": "ssh"},
        "namespace": {"type": "string", "minLength": 1},
        "allowed_signers": {"type": "string", "minLength": 1},
        "signature_file": {"type": "string", "minLength": 1},
        "signature_ext": {"type": "string", "pattern": "^\\..+"},
        "signer_identity": {"type": "string", "minLength": 1},
        "policy_mode": {"type": "string", "enum": ["advisory", "enforce"]},
        "require_verified_attestation_for_release_output": {"type": "boolean"},
        "require_verified_attestation_for_distribution": {"type": "boolean"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

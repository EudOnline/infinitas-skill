{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openai.invalid/infinitas-skill/provenance.schema.json",
  "title": "infinitas-skill release attestation",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "kind",
    "generated_at",
    "skill",
    "git",
    "source_snapshot",
    "registry",
    "dependencies",
    "review",
    "release",
    "attestation",
    "distribution"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "skill-release-attestation"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "skill": {
      "type": "object",
      "required": [
        "name",
        "version",
        "status",
        "path"
      ],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "publisher": {"type": ["string", "null"]},
        "qualified_name": {"type": ["string", "null"]},
        "identity_mode": {"type": ["string", "null"]},
        "version": {"type": "string", "minLength": 1},
        "status": {"type": ["string", "null"]},
        "path": {"type": "string", "minLength": 1},
        "author": {"type": ["string", "null"]},
        "owners": {"type": "array", "items": {"type": "string"}},
        "maintainers": {"type": "array", "items": {"type": "string"}},
        "derived_from": {"type": ["string", "null"]},
        "snapshot_of": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "git": {
      "type": "object",
      "required": [
        "commit",
        "expected_tag",
        "release_ref",
        "signed_tag_verified",
        "tag_signer"
      ],
      "properties": {
        "repo_url": {"type": ["string", "null"]},
        "branch": {"type": ["string", "null"]},
        "upstream": {"type": ["string", "null"]},
        "commit": {"type": "string", "minLength": 1},
        "head_commit": {"type": ["string", "null"]},
        "expected_tag": {"type": "string", "minLength": 1},
        "release_ref": {"type": "string", "minLength": 1},
        "remote": {"type": ["string", "null"]},
        "remote_tag_object": {"type": ["string", "null"]},
        "remote_tag_commit": {"type": ["string", "null"]},
        "signed_tag_verified": {"type": "boolean"},
        "tag_signer": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "source_snapshot": {
      "type": "object",
      "required": [
        "kind",
        "tag",
        "ref",
        "commit",
        "immutable",
        "pushed"
      ],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "tag": {"type": "string", "minLength": 1},
        "ref": {"type": "string", "minLength": 1},
        "commit": {"type": "string", "minLength": 1},
        "remote": {"type": ["string", "null"]},
        "upstream": {"type": ["string", "null"]},
        "immutable": {"type": "boolean"},
        "pushed": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "registry": {
      "type": "object",
      "required": [
        "default_registry",
        "registries_consulted",
        "resolved"
      ],
      "properties": {
        "default_registry": {"type": ["string", "null"]},
        "registries_consulted": {
          "type": "array",
          "items": {"type": "string"}
        },
        "resolved": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "registry_name": {"type": ["string", "null"]},
              "registry_kind": {"type": ["string", "null"]},
              "registry_url": {"type": ["string", "null"]},
              "registry_host": {"type": ["string", "null"]},
              "registry_priority": {"type": ["integer", "number"]},
              "registry_trust": {"type": ["string", "null"]},
              "registry_root": {"type": ["string", "null"]},
              "registry_pin_mode": {"type": ["string", "null"]},
              "registry_pin_value": {"type": ["string", "null"]},
              "registry_ref": {"type": ["string", "null"]},
              "registry_allowed_refs": {"type": "array", "items": {"type": "string"}},
              "registry_allowed_hosts": {"type": "array", "items": {"type": "string"}},
              "registry_update_mode": {"type": ["string", "null"]},
              "registry_commit": {"type": ["string", "null"]},
              "registry_tag": {"type": ["string", "null"]},
              "registry_branch": {"type": ["string", "null"]},
              "registry_origin_url": {"type": ["string", "null"]},
              "registry_origin_host": {"type": ["string", "null"]},
              "missing": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "dependencies": {
      "type": "object",
      "required": [
        "mode",
        "root",
        "steps",
        "registries_consulted"
      ],
      "properties": {
        "mode": {"type": ["string", "null"]},
        "root": {
          "type": "object",
          "properties": {
            "name": {"type": ["string", "null"]},
            "publisher": {"type": ["string", "null"]},
            "qualified_name": {"type": ["string", "null"]},
            "version": {"type": ["string", "null"]},
            "registry": {"type": ["string", "null"]},
            "stage": {"type": ["string", "null"]},
            "path": {"type": ["string", "null"]}
          },
          "additionalProperties": true
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "order": {"type": ["integer", "number"]},
              "name": {"type": ["string", "null"]},
              "publisher": {"type": ["string", "null"]},
              "qualified_name": {"type": ["string", "null"]},
              "identity_mode": {"type": ["string", "null"]},
              "version": {"type": ["string", "null"]},
              "registry": {"type": ["string", "null"]},
              "stage": {"type": ["string", "null"]},
              "path": {"type": ["string", "null"]},
              "relative_path": {"type": ["string", "null"]},
              "action": {"type": ["string", "null"]},
              "needs_apply": {"type": "boolean"},
              "requested_by": {"type": "array"},
              "depends_on": {"type": "array"},
              "conflicts_with": {"type": "array"},
              "root": {"type": "boolean"},
              "source_commit": {"type": ["string", "null"]},
              "source_ref": {"type": ["string", "null"]},
              "source_tag": {"type": ["string", "null"]}
            },
            "additionalProperties": true
          }
        },
        "registries_consulted": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "required": [
        "reviewers"
      ],
      "properties": {
        "reviewers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reviewer": {"type": ["string", "null"]},
              "decision": {"type": ["string", "null"]},
              "at": {"type": ["string", "null"]},
              "note": {"type": ["string", "null"]}
            },
            "additionalProperties": true
          }
        },
        "effective_review_state": {"type": ["string", "null"]},
        "required_approvals": {"type": ["integer", "null"]},
        "required_groups": {
          "type": "array",
          "items": {"type": "string"}
        },
        "covered_groups": {
          "type": "array",
          "items": {"type": "string"}
        },
        "missing_groups": {
          "type": "array",
          "items": {"type": "string"}
        },
        "approval_count": {"type": ["integer", "null"]},
        "blocking_rejection_count": {"type": ["integer", "null"]},
        "quorum_met": {"type": ["boolean", "null"]},
        "review_gate_pass": {"type": ["boolean", "null"]},
        "latest_decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reviewer": {"type": ["string", "null"]},
              "decision": {"type": ["string", "null"]},
              "at": {"type": ["string", "null"]},
              "note": {"type": ["string", "null"]},
              "groups": {
                "type": "array",
                "items": {"type": "string"}
              },
              "counted": {"type": ["boolean", "null"]},
              "reasons": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "additionalProperties": true
          }
        },
        "ignored_decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reviewer": {"type": ["string", "null"]},
              "decision": {"type": ["string", "null"]},
              "at": {"type": ["string", "null"]},
              "note": {"type": ["string", "null"]},
              "groups": {
                "type": "array",
                "items": {"type": "string"}
              },
              "counted": {"type": ["boolean", "null"]},
              "reasons": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "additionalProperties": true
          }
        },
        "configured_groups": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "members": {
                "type": "array",
                "items": {"type": "string"}
              },
              "teams": {
                "type": "array",
                "items": {"type": "string"}
              },
              "resolved_members": {
                "type": "array",
                "items": {"type": "string"}
              },
              "description": {"type": ["string", "null"]}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "release": {
      "type": "object",
      "required": [
        "releaser_identity",
        "transfer_required",
        "transfer_authorized",
        "authorized_signers",
        "authorized_releasers"
      ],
      "properties": {
        "releaser_identity": {"type": ["string", "null"]},
        "namespace_policy_path": {"type": ["string", "null"]},
        "namespace_policy_version": {"type": ["integer", "null"]},
        "transfer_required": {"type": "boolean"},
        "transfer_authorized": {"type": "boolean"},
        "transfer_matches": {"type": "array"},
        "competing_claims": {"type": "array"},
        "delegated_teams": {
          "type": "object",
          "properties": {
            "owner_teams": {
              "type": "array",
              "items": {"type": "string"}
            },
            "maintainer_teams": {
              "type": "array",
              "items": {"type": "string"}
            },
            "authorized_signer_teams": {
              "type": "array",
              "items": {"type": "string"}
            },
            "authorized_releaser_teams": {
              "type": "array",
              "items": {"type": "string"}
            }
          },
          "additionalProperties": true
        },
        "authorized_signers": {"type": "array", "items": {"type": "string"}},
        "authorized_releasers": {"type": "array", "items": {"type": "string"}},
        "exception_usage": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": ["string", "null"]},
              "scope": {"type": ["string", "null"]},
              "skills": {
                "type": "array",
                "items": {"type": "string"}
              },
              "rules": {
                "type": "array",
                "items": {"type": "string"}
              },
              "matched_rules": {
                "type": "array",
                "items": {"type": "string"}
              },
              "approved_by": {
                "type": "array",
                "items": {"type": "string"}
              },
              "approved_by_teams": {
                "type": "array",
                "items": {"type": "string"}
              },
              "resolved_approved_by": {
                "type": "array",
                "items": {"type": "string"}
              },
              "approved_at": {"type": ["string", "null"]},
              "justification": {"type": ["string", "null"]},
              "expires_at": {"type": ["string", "null"]}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "attestation": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "format",
            "namespace",
            "allowed_signers",
            "signature_file",
            "signature_ext",
            "signer_identity",
            "policy_mode",
            "require_verified_attestation_for_release_output",
            "require_verified_attestation_for_distribution"
          ],
          "properties": {
            "format": {"type": "string", "const": "ssh"},
            "namespace": {"type": "string", "minLength": 1},
            "allowed_signers": {"type": "string", "minLength": 1},
            "signature_file": {"type": "string", "minLength": 1},
            "signature_ext": {"type": "string", "pattern": "^\\..+"},
            "signer_identity": {"type": "string", "minLength": 1},
            "policy_mode": {"type": "string", "enum": ["advisory", "enforce"]},
            "require_verified_attestation_for_release_output": {"type": "boolean"},
            "require_verified_attestation_for_distribution": {"type": "boolean"}
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": [
            "format",
            "generator",
            "policy_mode",
            "require_verified_attestation_for_release_output",
            "require_verified_attestation_for_distribution"
          ],
          "properties": {
            "format": {"type": "string", "const": "ci"},
            "generator": {"type": "string", "minLength": 1},
            "output_name": {"type": "string", "minLength": 1},
            "policy_mode": {"type": "string", "enum": ["advisory", "enforce"]},
            "require_verified_attestation_for_release_output": {"type": "boolean"},
            "require_verified_attestation_for_distribution": {"type": "boolean"}
          },
          "additionalProperties": true
        }
      ]
    },
    "ci": {
      "type": "object",
      "required": [
        "provider",
        "repository",
        "workflow",
        "run_id",
        "run_attempt",
        "sha",
        "ref"
      ],
      "properties": {
        "provider": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "minLength": 1},
        "workflow": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "run_attempt": {"type": "string", "minLength": 1},
        "sha": {"type": "string", "minLength": 1},
        "ref": {"type": "string", "minLength": 1},
        "event_name": {"type": ["string", "null"]},
        "url": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "distribution": {
      "type": "object",
      "required": [
        "manifest_path",
        "bundle"
      ],
      "properties": {
        "manifest_path": {"type": "string", "minLength": 1},
        "bundle": {
          "type": "object",
          "required": [
            "path",
            "format",
            "sha256",
            "size",
            "root_dir",
            "file_count"
          ],
          "properties": {
            "path": {"type": "string", "minLength": 1},
            "format": {"type": "string", "const": "tar.gz"},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "size": {"type": "integer", "minimum": 0},
            "root_dir": {"type": "string", "minLength": 1},
            "file_count": {"type": "integer", "minimum": 1}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinitas-skill.local/schemas/review-evidence.schema.json",
  "title": "Review Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "entries"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "path": {
      "type": "string",
      "description": "File system path of the evidence file"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceEntry"
      }
    }
  },
  "$defs": {
    "evidenceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "source_kind",
        "source_ref",
        "reviewer",
        "decision",
        "at"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "source_kind": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "approved",
            "rejected"
          ]
        },
        "at": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

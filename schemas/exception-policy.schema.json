{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinitas-skill.local/schemas/exception-policy.schema.json",
  "title": "Exception Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "exceptions"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "scope",
          "skills",
          "rules",
          "approved_at",
          "justification",
          "expires_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "scope": {
            "type": "string",
            "enum": [
              "promotion",
              "release"
            ]
          },
          "skills": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?:/[a-z0-9]+(?:-[a-z0-9]+)*)?$"
            }
          },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          },
          "approved_by": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "approved_by_teams": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          },
          "justification": {
            "type": "string",
            "minLength": 1
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "anyOf": [
          {
            "required": [
              "approved_by"
            ]
          },
          {
            "required": [
              "approved_by_teams"
            ]
          }
        ]
      }
    }
  }
}
